# Example environment variables for Colab Keeper
# Copy this to a .env file or set them in your environment

# URL of the Colab notebook to open
COLAB_NOTEBOOK_URL="https://colab.research.google.com/github/HamzaYslmn/Colab-Ollama-Server-Free/blob/main/server.ipynb"

# Interval between regular runs (hours)
COLAB_INTERVAL_HOURS=5

# Interval between creating a new copy (hours)
COLAB_COPY_INTERVAL_HOURS=12

# Chrome profile directory to persist login (absolute path)
CHROME_USER_DATA_DIR="C:\\colab_profile"

# Enable automatic copy rotation (1 = enabled, 0 = disabled)
ENABLE_AUTO_COPY=1
